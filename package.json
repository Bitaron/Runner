{
  "name": "apiforge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@apiforge/web",
    "dev:api": "npm run dev --workspace=@apiforge/api",
    "start": "npm run start:services",
    "start:web": "npm run dev --workspace=@apiforge/web",
    "start:api": "npm run dev --workspace=@apiforge/api",
    "start:services": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "build": "npm run build --workspaces",
    "build:shared": "npm run build --workspace=@apiforge/shared",
    "build:web": "npm run build --workspace=@apiforge/web",
    "build:api": "npm run build --workspace=@apiforge/api",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules node_modules",
    "docker:up": "cd docker && docker-compose up -d",
    "docker:down": "cd docker && docker-compose down",
    "docker:logs": "cd docker && docker-compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
